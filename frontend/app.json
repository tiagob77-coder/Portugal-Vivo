{
  "expo": {
    "name": "Portugal Vivo",
    "slug": "portugal-vivo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "portugalvivo",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pt.portugalvivo",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Descubra património cultural perto de si",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Receba alertas de locais culturais próximos mesmo quando a app está em segundo plano.",
        "NSCameraUsageDescription": "A realidade aumentada Time-Travel usa a câmara para sobrepor reconstruções históricas ao mundo real",
        "NSPhotoLibraryUsageDescription": "Adicione fotos da sua galeria",
        "UIBackgroundModes": ["fetch", "remote-notification", "location"]
      }
    },
    "android": {
      "package": "pt.portugalvivo",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#000000",
          "dark": {
            "image": "./assets/images/splash-image.png",
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-camera",
        {
          "cameraPermission": "A funcionalidade Time-Travel usa a câmara para sobrepor reconstruções históricas ao vivo."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon-192.png",
          "color": "#8B5CF6",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Portugal Vivo",
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-task-manager"
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Receba alertas de locais culturais próximos mesmo quando a app está em segundo plano.",
          "locationWhenInUsePermission": "Descubra património cultural perto de si.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "./plugins/withPrivacyManifest.js"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
