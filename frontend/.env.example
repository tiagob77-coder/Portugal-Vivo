# Portugal Vivo — Frontend Environment Variables
# Copy to .env and fill in your values: cp .env.example .env
# Expo Public vars são expostas no bundle (não colocar segredos aqui)

# Google Maps (usado em category/[id], route/[id], heritage/[id], route-planner)
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# URL do backend (dev: porta 8001; produção: domínio HTTPS)
# Dev:
EXPO_PUBLIC_BACKEND_URL=http://localhost:8001
# Produção (definido no eas.json para builds EAS):
# EXPO_PUBLIC_BACKEND_URL=https://api.portugalvivo.pt

# Modo de desenvolvimento (true = bypass de alguns guards; não usar em produção)
EXPO_PUBLIC_DEV_MODE=false

# Monitorização Sentry (deixar vazio para desativar)
EXPO_PUBLIC_SENTRY_DSN=
EXPO_PUBLIC_ENVIRONMENT=development
EXPO_PUBLIC_APP_VERSION=0.0.0
