# =============================================================================
# Portugal Vivo — Variáveis de Ambiente
# Copiar para .env e preencher todos os valores: cp .env.example .env
# NUNCA commitar o ficheiro .env real
# =============================================================================

# --- Ambiente ---
# Valores possíveis: development | staging | production
ENVIRONMENT=development

# Versão da app (usada no Sentry release tag e headers de resposta)
APP_VERSION=0.0.0

# --- Base de Dados ---
MONGO_URL=mongodb://localhost:27017
DB_NAME=portugal_vivo

# Em Docker Compose usar:
# MONGO_URL=mongodb://mongodb:27017

# --- Redis (leaderboard, cache) ---
REDIS_URL=redis://localhost:6379

# Em Docker Compose usar:
# REDIS_URL=redis://redis:6379

# --- Autenticação ---
# Gerar com: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=change-me-to-a-random-secret-minimum-32-chars

# Chave secreta para endpoints de admin internos
ADMIN_SECRET=change-me-admin-secret

# URL do backend de autenticação delegado (vazio = autenticação local JWT)
AUTH_BACKEND_URL=

# Google OAuth2 — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- IA / LLM (IQ Engine, narrativas culturais) ---
# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Emergent LLM (plataforma de dev)
EMERGENT_LLM_KEY=

# --- Pagamentos — Stripe ---
# Dashboard: https://dashboard.stripe.com/apikeys
# Usar chaves sk_test_... em dev, sk_live_... em produção
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# IDs de preço do produto Stripe (criar em Products > Pricing)
# Discovridor Mensal — €4,99/mês
STRIPE_PRICE_PREMIUM=
# Guardião Anual — €39,99/ano
STRIPE_PRICE_ANNUAL=

# --- Pagamentos — MB Way / Multibanco (opcional) ---
# Integrador: Stripe + Easypay ou similar
MBWAY_MERCHANT_ID=
MBWAY_API_KEY=
MULTIBANCO_ENTITY=
MULTIBANCO_SUBENTITY=

# --- Mapas ---
# Google Maps — https://console.cloud.google.com/google/maps-apis/credentials
GOOGLE_MAPS_API_KEY=

# --- Imagens (Cloudinary) ---
# Dashboard: https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Unsplash (enriquecimento automático de imagens de POIs)
# https://unsplash.com/developers → New Application
UNSPLASH_ACCESS_KEY=

# --- Monitorização ---
# Sentry — https://sentry.io/settings/ → Projects → DSN
SENTRY_DSN=
# Taxa de amostragem de performance traces (0.0 a 1.0; 0.1 = 10%)
SENTRY_TRACES_SAMPLE_RATE=0.1

LOG_LEVEL=INFO
# Em produção usar "json" para logs estruturados (Datadog, CloudWatch, Loki)
LOG_FORMAT=text

# Alertas de performance/erros via webhook (Slack, Discord, Teams)
# Formato: https://hooks.slack.com/services/...
ALERT_WEBHOOK_URL=
ALERT_THRESHOLD_ERROR_RATE=0.05
ALERT_THRESHOLD_RESPONSE_MS=2000
ALERT_COOLDOWN_SECONDS=300

# --- CORS ---
# Separar por vírgula. Em produção usar apenas os domínios reais.
# Dev:
ALLOWED_ORIGINS=http://localhost:19006,http://localhost:8081,http://localhost:3000
# Produção (exemplo):
# ALLOWED_ORIGINS=https://portugalvivo.pt,https://www.portugalvivo.pt,https://app.portugalvivo.pt

# --- Domínios (para geração de links) ---
APP_BASE_URL=https://portugalvivo.pt
API_BASE_URL=https://api.portugalvivo.pt

# --- Backups MongoDB ---
# Directório local onde os dumps ficam guardados
BACKUP_DIR=/app/backups
# Política de retenção (número de cópias a manter)
RETAIN_DAILY=7
RETAIN_WEEKLY=4
RETAIN_MONTHLY=3

# AWS S3 para backups remotos (opcional — deixar vazio para só backup local)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=eu-west-1
S3_BACKUP_BUCKET=
S3_BACKUP_PREFIX=mongodb-backups/
